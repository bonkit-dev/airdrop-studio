{
  "name": "@bonkit/airdrop-studio",
  "version": "0.1.0",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bonkit-dev/airdrop-studio.git"
  },
  "bin": {
    "airdrop-studio": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "src/runtime"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && vite build --config studio-app/vite.config.ts",
    "dev:studio": "node --import tsx src/dev/run-studio-dev.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p studio-app/tsconfig.json --noEmit",
    "prettier": "pnpm prettier --write packages/**/*.{ts.tsx}",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p studio-app/tsconfig.json --noEmit",
    "test": "node -e \"console.log('no tests yet for @bonkit/airdrop-studio')\""
  },
  "dependencies": {
    "@bonkit/airdrop-sdk": "^0.3.3",
    "@coral-xyz/anchor": "0.31.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "open": "^10.1.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@icons-pack/react-simple-icons": "^13.8.0",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@rollup/plugin-inject": "^5.0.5",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-wallets": "^0.19.37",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.564.0",
    "react": "^19.2.0",
    "react-day-picker": "^9.8.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.1.11",
    "vite-plugin-node-polyfills": "^0.26.0",
    "zustand": "^5.0.0"
  },
  "description": "CLI that launches a local browser-based studio for creating Solana airdrop campaign pages.",
  "keywords": [
    "solana",
    "airdrop",
    "campaign",
    "studio",
    "bonkit"
  ],
  "license": "MIT",
  "author": "Bonkit-Dev",
  "homepage": "https://github.com/bonkit-dev/airdrop-studio#readme",
  "bugs": {
    "url": "https://github.com/bonkit-dev/airdrop-studio/issues"
  }
}
